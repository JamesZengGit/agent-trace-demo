# Copy to .env and fill in to enable the Chat feature (POST /api/chat + the
# dashboard Chat page). Without a key, chat is simply disabled; the rest of
# the stack runs normally.
#
#   cp .env.example .env   &&   edit   &&   make up
#
# .env is gitignored — the key never gets committed and never reaches the browser.

OPENAI_API_KEY=

# Provider is swappable by base URL. OpenAI by default; point at a self-hosted
# vLLM server (OpenAI-compatible) to switch with no code change:
#   OPENAI_BASE_URL=http://vllm:8000/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
